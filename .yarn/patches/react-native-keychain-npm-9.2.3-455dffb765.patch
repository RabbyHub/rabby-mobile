+
+internal fun resolveCipherStorageName(cipherStorageName: String?): String {
+  if (cipherStorageName != null) {
+    return cipherStorageName
+  }
+
+  // Rabby's legacy Android biometric entries were persisted with RSA-backed keychain storage
+  // before the cipher marker was written. Keep resolving those migrated records as RSA so
+  // upgrades can still decrypt and rehydrate existing biometrics state.
+  return KnownCiphers.RSA
+}

@@ -0,0 +1,19 @@
+package com.oblador.keychain
+
+import org.junit.Assert.assertEquals
+import org.junit.Test
+
+class DataStorePrefsStorageTest {
+  @Test
+  fun legacySharedPreferencesEntriesWithoutCipherMarkerDefaultToRsa() {
+    assertEquals(KeychainModule.KnownCiphers.RSA, resolveCipherStorageName(null))
+  }
+
+  @Test
+  fun existingCipherMarkerIsPreserved() {
+    assertEquals(
+      KeychainModule.KnownCiphers.RSA,
+      resolveCipherStorageName(KeychainModule.KnownCiphers.RSA),
+    )
+  }
+}

+  private fun getSha256Fingerprint(input: ByteArray): String {
+    val digest = MessageDigest.getInstance("SHA-256").digest(input)
+    val builder = StringBuilder(digest.size * 3 - 1)
+
+    digest.forEachIndexed { index, value ->
+      if (index > 0) {
+        builder.append(':')
+      }
+
+      val unsignedValue = value.toInt() and 0xFF
+      if (unsignedValue < 0x10) {
+        builder.append('0')
+      }
+      builder.append(unsignedValue.toString(16).uppercase())
+    }
+
+    return builder.toString()
+  }

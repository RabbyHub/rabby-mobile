require 'base64'

def turbo_build_enabled?
  ENV['RABBY_MOBILE_TURBO_BUILD'] == 'true'
end

def turbo_ios_derived_data_path
  path = ENV['RABBY_MOBILE_TURBO_IOS_DERIVED_DATA_PATH']
  return path unless path.nil? || path.empty?

  './ios/DerivedData'
end

def ios_adhoc_archive_path
  path = ENV['RABBY_MOBILE_IOS_ARCHIVE_PATH']
  return path unless path.nil? || path.empty?

  './ios/Package/adhoc/RabbyMobile.xcarchive'
end

def ios_adhoc_skip_build_archive?
  ENV['RABBY_MOBILE_IOS_SKIP_BUILD_ARCHIVE'] == 'true'
end

platform :ios do
  private_lane :load_app_store_connect_api_key_for_testflight do
    key_id = ENV["RABBY_MOBILE_ASC_API_KEY_ID"]
    issuer_id = ENV["RABBY_MOBILE_ASC_API_ISSUER_ID"]
    key_content_base64 = ENV["RABBY_MOBILE_ASC_API_PRIVATE_KEY_BASE64"]
    duration = (ENV["RABBY_MOBILE_ASC_API_TOKEN_DURATION"] || Spaceship::ConnectAPI::Token::DEFAULT_TOKEN_DURATION).to_i
    in_house = ENV["RABBY_MOBILE_ASC_API_IN_HOUSE"] == 'true'

    if key_id.to_s.empty?
      UI.user_error!("Missing App Store Connect API key id: RABBY_MOBILE_ASC_API_KEY_ID")
    end

    if issuer_id.to_s.empty?
      UI.user_error!("Missing App Store Connect API issuer id: RABBY_MOBILE_ASC_API_ISSUER_ID")
    end

    if key_content_base64.to_s.empty?
      UI.user_error!("Missing App Store Connect API private key: RABBY_MOBILE_ASC_API_PRIVATE_KEY_BASE64")
    end

    app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_content_base64,
      is_key_content_base64: true,
      duration: duration,
      in_house: in_house
    )
  end

  private_lane :latest_testflight_build_number_for_version do |opts|
    latest_testflight_build_number(
      api_key: opts[:api_key],
      app_identifier: opts[:app_identifier],
      version: opts[:version],
      platform: 'ios',
      initial_build_number: 0
    ).to_i
  end

  private_lane :wait_for_uploaded_testflight_build do |opts|
    timeout_seconds = (ENV['RABBY_MOBILE_ASC_UPLOAD_VERIFY_TIMEOUT_SECONDS'] || '1800').to_i
    interval_seconds = (ENV['RABBY_MOBILE_ASC_UPLOAD_VERIFY_INTERVAL_SECONDS'] || '30').to_i
    app_identifier = opts[:app_identifier]
    version = opts[:version]
    api_key = opts[:api_key]
    baseline_build_number = opts[:baseline_build_number].to_i
    started_at = Time.now

    loop do
      latest_build_number = latest_testflight_build_number_for_version(
        api_key: api_key,
        app_identifier: app_identifier,
        version: version
      )

      if latest_build_number > baseline_build_number
        UI.success("Detected new TestFlight build on App Store Connect: #{version}(#{latest_build_number})")
        return latest_build_number
      end

      elapsed_seconds = (Time.now - started_at).to_i
      if elapsed_seconds >= timeout_seconds
        UI.user_error!("Upload did not produce a new TestFlight build within #{timeout_seconds}s. version=#{version} baseline_build_number=#{baseline_build_number} latest_build_number=#{latest_build_number}")
      end

      UI.message("Waiting for a new TestFlight build to appear on App Store Connect for version #{version}. baseline=#{baseline_build_number} latest=#{latest_build_number} elapsed=#{elapsed_seconds}s")
      sleep(interval_seconds)
    end
  end

  private_lane :prepare_apple_sign do |opts|
    # setup_ci

    # # enforce configuration
    # update_code_signing_settings(
    #   use_automatic_signing: false,
    #   targets: ['RabbyMobile'],
    #   sdk: "iphoneos*",
    #   path: './ios/RabbyMobile.xcodeproj',
    #   profile_name: opts[:type] == 'adhoc' ? 'RabbyMobileAdHocRegressionOpcode' : 'RabbyMobileAppStoreOpcode',
    #   bundle_identifier: opts[:type] == 'adhoc' ? 'com.debank.rabby-mobile-regression' : 'com.debank.rabby-mobile',
    # )

    ENV['CONFIGURATION'] = opts[:type] == 'adhoc' ? 'Regression' : 'Release'

    # Main App: RabbyMobile
    match(
      type: opts[:type],
      app_identifier: opts[:type] == 'adhoc' ? 'com.debank.rabby-mobile-regression' : 'com.debank.rabby-mobile',
      profile_name: opts[:type] == 'adhoc' ? 'RabbyMobileAdHocRegressionOpcode' : 'RabbyMobileAppStoreOpcode',
      readonly: true,
      shallow_clone: true,
      verbose: false,
      force_for_new_devices: true,
      clone_branch_directly: true)

    # # App Extension: RabbyMobileNotification
    # match(
    #   type: opts[:type],
    #   app_identifier: opts[:type] == 'adhoc' ? 'com.debank.rabby-mobile*' : 'com.debank.rabby-mobile.RabbyMobileNotification',
    #   profile_name: opts[:type] == 'adhoc' ? 'RabbyMobileWildcardAdHocRegression' : 'RabbyMobileNotificationAppStore',
    #   readonly: true,
    #   shallow_clone: true,
    #   verbose: false,
    #   force_for_new_devices: true,
    #   clone_branch_directly: true)
  end

  desc "Release for the iOS adhoc"
  lane :adhoc do
    prepare_apple_sign(type: 'adhoc')

    gym(
      scheme: 'RabbyMobileRegression',
      workspace: './ios/RabbyMobile.xcworkspace',
      configuration: 'Regression',
      output_directory: "./ios/Package/adhoc",
      build_path: "./ios/Package/adhoc",
      archive_path: ios_adhoc_archive_path,
      skip_build_archive: ios_adhoc_skip_build_archive?,
      derived_data_path: turbo_build_enabled? ? turbo_ios_derived_data_path : nil,
      destination: "generic/platform=iOS",
      clean: ios_adhoc_skip_build_archive? ? false : !turbo_build_enabled?,
      ## if you wanna output log to stdout, uncomment below 2 lines
      # xcodebuild_formatter: '',
      # suppress_xcode_output: false,
      skip_package_pkg: true,
      export_method: 'ad-hoc',
      # export_method: 'release-testing',
      export_options: {
        method: 'ad-hoc',
        signingStyle: 'manual',
        provisioningProfiles: {
          "com.debank.rabby-mobile-regression": "RabbyMobileAdHocRegressionOpcode",
          # "com.debank.rabby-mobile-regression.RabbyMobileNotification": "RabbyMobileWildcardAdHocRegression"
        },
        manifest: {
          appURL: "https://download.rabby.io/downloads/wallet-mobile/ios/rabbymobile.ipa",
          displayImageURL: "https://download.rabby.io/downloads/wallet-mobile/ios/icon_57x57@57w.png",
          fullSizeImageURL: "https://download.rabby.io/downloads/wallet-mobile/ios/icon_512x512@512w.png",
        }
      })

    # # shell executeb on ./fastlane directory, add `sh "pwd"` below to check it
    # sh "/usr/libexec/PlistBuddy -c \"Set:items:0:metadata:title Rabby Wallet\" ../ios/Package/adhoc/manifest.plist"
  end

  desc "Valid ios adhoc"
  lane :hashcheck do
    gym(
      scheme: 'RabbyMobile',
      workspace: './ios/RabbyMobile.xcworkspace',
      configuration: 'Release',
      output_directory: "./ios/Package",
      # build_path: "./ios/Package/adhoc",
      destination: "generic/platform=iOS",
      clean: true,
      ## if you wanna output log to stdout, uncomment below 2 lines
      xcodebuild_formatter: '',
      suppress_xcode_output: false,
      skip_package_ipa: true,
      skip_package_pkg: true,
      export_method: 'ad-hoc',
      derived_data_path: './ios/DerivedData',
      archive_path: './ios/Package/RabbyMobile.xcarchive',
      skip_codesigning: true,
      # skip_archive: true,
      # xcargs: "-jobs 1", # 禁用并行编译
      xcconfig: "./ios/RabbyMobile/ValidHash.xcconfig",
      buildlog_path: './ios/Package'
    )
  end

  desc "Release for the iOS production"
  lane :appstore do
      asc_api_key = load_app_store_connect_api_key_for_testflight
      current_version = get_version_number(
        xcodeproj: './ios/RabbyMobile.xcodeproj',
        target: 'RabbyMobile',
        configuration: 'Release'
      )
      baseline_build_number = latest_testflight_build_number_for_version(
        api_key: asc_api_key,
        app_identifier: 'com.debank.rabby-mobile',
        version: current_version
      )
      UI.message("Latest TestFlight build before upload for #{current_version}: #{baseline_build_number}")

      prepare_apple_sign(type: 'appstore')
      gym(
        scheme: 'RabbyMobile',
        workspace: './ios/RabbyMobile.xcworkspace',
        configuration: 'Release',
        output_directory: "./ios/Package/appstore",
        build_path: "./ios/Package/appstore",
        destination: "generic/platform=iOS",
        skip_profile_detection: true,
        clean: true,
        ## if you wanna output log to stdout, uncomment below 2 lines
        # xcodebuild_formatter: '',
        # suppress_xcode_output: false,
        skip_package_pkg: true,
        export_method: "app-store",
        verbose: true,
        export_options: {
          method: "app-store",
          signingStyle: 'manual',
          provisioningProfiles: {
            "com.debank.rabby-mobile": "RabbyMobileAppStoreOpcode",
            "com.debank.rabby-mobile.RabbyMobileNotification": "RabbyMobileNotificationAppStore"
          }
        })
      pilot(
        api_key: asc_api_key,
        apple_id: '6474381673',
        ipa: "./ios/Package/appstore/RabbyMobile.ipa",
        skip_waiting_for_build_processing: true,
        distribute_only: ENV["RABBY_MOBILE_PILOT_DISTRIBUTE_ONLY"] || false,
      )
      unless ENV["RABBY_MOBILE_PILOT_DISTRIBUTE_ONLY"] == 'true'
        wait_for_uploaded_testflight_build(
          api_key: asc_api_key,
          app_identifier: 'com.debank.rabby-mobile',
          version: current_version,
          baseline_build_number: baseline_build_number
        )
      end
  end
end

platform :android do
  private_lane :write_key_store do
    # keystore is stored as base64 from environment variable
    if !ENV["RABBY_MOBILE_ANDROID_KEY_STORE"].empty?
      File.open("../android/app/app-upload-key.keystore", 'w') do |file|
        file.write(Base64.decode64(ENV["RABBY_MOBILE_ANDROID_KEY_STORE"]))
      end
    end
  end

  private_lane :build_rabbymobile_app do |opts|
    gradle(tasks: opts[:tasks], project_dir: './android', properties: {
      "MYAPP_UPLOAD_STORE_FILE" => "app-upload-key.keystore",
      "MYAPP_UPLOAD_STORE_PASSWORD" => ENV['RABBY_MOBILE_ANDROID_STORE_PASSWORD'],
      "MYAPP_UPLOAD_KEY_ALIAS" => ENV['RABBY_MOBILE_ANDROID_KEY_ALIAS'],
      "MYAPP_UPLOAD_KEY_PASSWORD" => ENV['RABBY_MOBILE_ANDROID_KEY_PASSWORD']
    }.merge(opts.fetch(:properties, {})))

    android_version_code = android_get_version_code(gradle_file: "./android/app/build.gradle")
    android_version_name = android_get_version_name(gradle_file: "./android/app/build.gradle")
  end

  desc "Valid android adhoc"
  lane :hashcheck do |options|
    gradle(task: 'clean', project_dir: './android')
    build_rabbymobile_app(tasks: ['assembleHash'], properties: {
      "org.gradle.daemon"=>false,
      "org.gradle.caching"=>false,
      "org.gradle.parallel"=>false,
      "android.useAndroidX"=>true,
      "android.buildfeatures.buildId"=>false,
      "hashcheck" => true,
    })

    apk_path = lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH]

    destination_path = options[:destination_path]
    if destination_path
      begin
        FileUtils.cp(apk_path, destination_path)
        UI.success("Successfully copied APK to: #{destination_path}")
      rescue => ex
        UI.user_error!("Failed to copy APK from '#{apk_path}' to '#{destination_path}'. Error: #{ex}")
      end
    else
      sh "shasum -a 256 #{apk_path}"
    end

  end


  desc "Release for the Android selfhost"
  lane :selfhost do
    write_key_store
    use_cache = (ENV['RABBY_MOBILE_GRADLE_USE_CACHE'] == 'true' || turbo_build_enabled?) ? 'true' : 'false'
    build_channel = ENV['buildchannel'] || 'selfhost-reg'
    if build_channel == 'selfhost-reg'
      if use_cache == 'true'
        UI.message("Using Gradle cache for selfhost-reg build")
      else
        UI.message("Not using Gradle cache for selfhost-reg build")
        gradle(task: 'clean', project_dir: './android')
      end
      build_rabbymobile_app(tasks: ['assembleRegression'], properties: {
        "org.gradle.configuration-cache"=>use_cache == 'true',
        "org.gradle.caching"=>use_cache == 'true',
        "org.gradle.parallel"=>true,
      })
    else
      build_rabbymobile_app(tasks: ['assembleRelease'])
    end
  end

  desc "Release for the Android playstore"
  lane :playstore do
    write_key_store
    use_cache = turbo_build_enabled?
    if use_cache
      UI.message("Using Gradle cache for playstore build")
    else
      gradle(task: 'clean', project_dir: './android')
    end
    build_rabbymobile_app(tasks: ['assembleRelease', 'bundleRelease'], properties: {
      "org.gradle.configuration-cache"=>use_cache ? 'true' : 'false',
      "org.gradle.caching"=>use_cache ? 'true' : 'false',
      "org.gradle.parallel"=>use_cache ? 'true' : 'false',
    })
  end
end
